<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="#A7A1C5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Изменить запись"
        android:textSize="40sp"
        android:textStyle="bold"
        android:id="@+id/date_text"
        android:layout_gravity="center"
        android:textColor="#102343"
        android:layout_marginBottom="20dp"
        />
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Дата:"
            android:layout_marginLeft="10dp"
            android:textSize="25sp"
            android:textColor="#102343"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01.01"
            android:id="@+id/date_const"
            android:layout_marginLeft="5dp"
            android:textSize="25sp"
            android:textColor="#102343"/>
    </LinearLayout>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Настроение:"
        android:layout_marginLeft="10dp"
        android:textSize="25sp"
        android:textColor="#102343"/>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp">
        <ImageButton

            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/img_happy"
            android:layout_marginRight="5dp"
            android:id="@+id/img_happy"
            android:scaleType="centerInside"
            android:onClick="onMoodSelected"
            />
        <ImageButton
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/img_sad"
            android:layout_marginRight="5dp"
            android:id="@+id/img_sad"
            android:scaleType="centerInside"
            android:onClick="onMoodSelected"
            />
        <ImageButton
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerInside"
            android:src="@drawable/img_angry"
            android:layout_marginRight="5dp"
            android:id="@+id/img_angry"
            android:onClick="onMoodSelected"
            />
        <ImageButton
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/img_tired"
            android:layout_marginRight="5dp"
            android:id="@+id/img_tired"
            android:scaleType="centerInside"
            android:onClick="onMoodSelected"
            />
    </LinearLayout>


    <com.google.android.material.textfield.TextInputLayout
        android:layout_margin="16dp"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:hint="Заметка"
        app:boxBackgroundColor="@color/white"
        app:boxBackgroundMode="filled"
        app:boxCornerRadiusBottomEnd="16dp"
        app:boxCornerRadiusBottomStart="16dp"
        app:boxCornerRadiusTopEnd="16dp"
        app:boxCornerRadiusTopStart="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/enter_notes"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:background="@null"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:minLines="6"
            android:textColor="#102343"
            android:textColorHint="@color/white" />
    </com.google.android.material.textfield.TextInputLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
    <Button
        android:id="@+id/btn_goback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="right"
        android:layout_marginLeft="70dp"
        android:layout_marginRight="10dp"
        android:text="Отмена"
        android:textColor="@color/text_color"
        android:backgroundTint="@color/select_color"
        android:textSize="20sp"/>
    <Button
        android:id="@+id/btn_send_edit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="right"
        android:layout_marginRight="10dp"
        android:text="Изменить"
        android:textColor="@color/text_color"
        android:backgroundTint="@color/select_color"
        android:textSize="20sp"/>
    </LinearLayout>


</LinearLayout>
