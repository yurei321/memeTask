<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="#A7A1C5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Добавить запись"
        android:textSize="40sp"
        android:textStyle="bold"
        android:id="@+id/date_text"
        android:layout_gravity="center"
        android:textColor="#102343"
        android:layout_marginBottom="20dp"
        />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Настроение:"
        android:textSize="25sp"
        android:textColor="#102343"/>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginBottom="20dp">
        <ImageButton

            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/img_happy"
            android:layout_marginRight="5dp"
            android:id="@+id/img_happy"
            android:scaleType="centerInside"
            android:onClick="onMoodSelected"
            />
        <ImageButton
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/img_sad"
            android:layout_marginRight="5dp"
            android:id="@+id/img_sad"
            android:scaleType="centerInside"
            android:onClick="onMoodSelected"
            />
        <ImageButton
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerInside"
            android:src="@drawable/img_angry"
            android:layout_marginRight="5dp"
            android:id="@+id/img_angry"
            android:onClick="onMoodSelected"
            />
        <ImageButton
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/img_tired"
            android:layout_marginRight="5dp"
            android:id="@+id/img_tired"
            android:scaleType="centerInside"
            android:onClick="onMoodSelected"
            />
    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Дата:"
            android:textSize="25sp"
            android:textColor="#102343"/>
        <EditText
            android:id="@+id/enter_date"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:background="#fff"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Заметки:"
            android:textSize="25sp"
            android:textColor="#102343"/>
        <EditText
            android:id="@+id/enter_notes"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:background="#fff"
            android:padding="3dp"/>
    </LinearLayout>
    <Button
        android:id="@+id/btn_send_new"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="right"
        android:layout_marginRight="25dp"
        android:text="Отправить"
        android:textSize="20sp"/>


</LinearLayout>
